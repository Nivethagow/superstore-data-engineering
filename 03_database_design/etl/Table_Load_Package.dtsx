                  description="The SQL command to be executed."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT s.product_name, sc.subcategory_id, m.manufactory_id
FROM stg_superstore_data s
JOIN Subcategory sc ON s.subcategory = sc.subcategory
JOIN Manufactory m ON s.manufactory = m.manufactory
WHERE NOT EXISTS (
    SELECT 1 
    FROM Product p 
    WHERE p.product_name = s.product_name
);</property>
