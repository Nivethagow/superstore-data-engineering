                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
    s.order_id,
    STR_TO_DATE(MIN(s.order_date), '%m/%d/%Y') AS order_date,
    STR_TO_DATE(MIN(s.ship_date), '%m/%d/%Y') AS ship_date,
    MIN(c.customer_id) AS customer_id
FROM stg_superstore_data s
JOIN Customer c ON s.customer = c.customer_name
WHERE NOT EXISTS (
    SELECT 1 FROM Orders o WHERE o.order_id = s.order_id
)
GROUP BY s.order_id;</property>
