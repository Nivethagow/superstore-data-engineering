                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT 
    s.customer,
    s.segment,
    c.city_id
FROM stg_superstore_data s
JOIN City c 
  ON s.city = c.city 
 AND s.state = c.state 
 AND s.zip = c.zip
WHERE NOT EXISTS (
